{
  "name": "foxglove-cloudini-converter",
  "displayName": "foxglove-cloudini-converter",
  "description": "A Foxglove extension to read CompressedPointCloud2 messages generated by Cloudini",
  "publisher": "Cloudini",
  "homepage": "https://github.com/facontidavide/cloudini",
  "version": "1.2.1",
  "license": "MIT",
  "main": "./dist/extension.js",
  "keywords": [],
  "scripts": {
    "build": "foxglove-extension build",
    "foxglove:prepare-wasm": "node ./scripts/prepare-wasm.cjs",
    "foxglove:prepublish": "npm run foxglove:prepare-wasm && foxglove-extension build --mode production",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "lint:fix": "eslint --fix .",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package -o release/cloudini.foxglove-cloudini-converter-$npm_package_version.foxe",
    "pretest": "foxglove-extension pretest"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.1.2",
    "@foxglove/extension": "^2.50.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "create-foxglove-extension": "1.3.1",
    "eslint": "^9.27.0",
    "prettier": "3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "style-loader": "^4.0.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@foxglove/schemas": "^2.0.0",
    "css-loader": "^7.1.4"
  }
}
